              "id": "f75582f5-71dd-4fe0-b447-c2fef6cdcd68",
              "name": "newsletter_output",
              "value": "={{ (() => {\n  let html = $json.output[0].content[0].text;\n\n  // Convert headings\n  html = html.replace(/<h1>(.*?)<\\/h1>/gi, '*$1*\\n');\n  html = html.replace(/<h2>(.*?)<\\/h2>/gi, '*$1*\\n');\n\n  // Convert paragraphs\n  html = html.replace(/<p>(.*?)<\\/p>/gi, '$1\\n');\n\n  // Convert list items\n  html = html.replace(/<li>(.*?)<\\/li>/gi, '• $1\\n');\n\n  // Remove remaining tags\n  html = html.replace(/<[^>]+>/g, '');\n\n  // Clean extra spaces/newlines\n  html = html.replace(/\\n\\s*\\n/g, '\\n\\n').trim();\n\n  return html;\n})() }}",
              "type": "string"
            }
          ]
        },
