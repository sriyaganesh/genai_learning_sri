              "id": "3b7681ab-fb4d-4d1f-ab22-27886d188677",
              "name": "is_valid",
              "value": "={{ (() => {\n  const text = ($json.text || \"\").trim();\n  const parts = text.split('|');\n\n  if (parts.length !== 2) return false;\n\n  const topic = parts[0].trim().toLowerCase();\n  const method = parts[1].trim().toLowerCase();\n\n  // Basic format checks\n  if (!topic || topic.length < 5) return false;\n  if (!['slack','email'].includes(method)) return false;\n\n  // ❌ Reject weak / generic topics\n  const invalidTopics = [\n    \"hi\",\"hello\",\"hey\",\"test\",\"ok\",\"yes\",\"no\",\"abc\",\"random\"\n  ];\n\n  if (invalidTopics.includes(topic)) return false;\n\n  // ❌ Reject single-word topics\n  if (topic.split(\" \").length < 2) return false;\n\n  return true;\n})() }}",
              "type": "string"
            },
